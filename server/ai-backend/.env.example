# AI Assistant Backend Configuration

# Server Port
PORT=3001

# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=phi
MAX_CONTEXT_MESSAGES=3
MAX_RESPONSE_TOKENS=140
OLLAMA_TEMPERATURE=0.3
OLLAMA_NUM_CTX=1024
OLLAMA_TIMEOUT_MS=30000
OLLAMA_HEALTH_TTL_MS=15000
KNOWLEDGE_TOP_K=5
KNOWLEDGE_MAX_CHARS_PER_SNIPPET=500

# Environment
NODE_ENV=production
